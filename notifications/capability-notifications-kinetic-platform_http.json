          "method": "GET",
          "includeEmptyParams": false,
          "followRedirect": false,
          "streamResponse": false
        },
        "outputs": {
          "CID": {
            "value": "body.teams[0]?.attributesMap['CID']"
          },
          "Description": {
            "value": "body.teams[0]?.description"
          },
          "Manager": {
            "value": "body.teams[0]?.attributesMap.Manager[0]"
          },
          "Member Email List": {
            "value": "body.teams[0]?.memberships.map(m => m.user.email).join(',')"
          },
