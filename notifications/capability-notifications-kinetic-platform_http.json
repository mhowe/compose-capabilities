            "children": {
              "Profile Attributes Map": "current.user['profileAttributesMap']",
              "User Display Name": "current.user['displayName']",
              "User Email": "current.user['email']",
              "User Name": "current.user['username']",
              "User Preferred Locale": "current.user['preferredLocale']"
            },
            "value": "body.teams[0]?.memberships"
          },
          "Name": {
            "value": "body.teams[0]?.name"
          },
          "Notification Delivery Method": {
            "value": "body.teams[0]?.attributesMap['Notification Delivery Method'][0]"
          },
          "Notification Delivery Target": {
            "value": "body.teams[0]?.attributesMap['Notification Delivery Target']"
          },
          "Slug": {
            "value": "body.teams[0]?.slug"
          },
