            "events": [
              {
                "name": "Set Drop Down Options",
                "code": "// Single source of truth — add a row here when you add a new channel\nconst DELIVERY_METHODS = [\n  {\n    value: 'Individual',\n    label: 'Individual (Individual team member notifications following their preferences)',\n    appliesTo: ['Team'],\n    // always available — no gate\n  },\n  {\n    value: 'Email',\n    label: 'Email (Default option)',\n    appliesTo: ['User'],\n  },\n  {\n    value: 'Group Email',\n    label: 'Group Email (A single email address for the team)',\n    appliesTo: ['Team'],\n  },\n  {\n    value: 'Slack',\n    label: 'Slack (Message posted to Slack Channel)',\n    appliesTo: ['Team'],\n    gate: 'Slack Integration', // the gate is the name of the Kapp Slug\n  },\n  {\n    value: 'Slack',\n    label: 'Slack (Message posted in Slack)',\n    appliesTo: ['User'],\n    gate: 'Slack Integration',  // the gate is the name of the Kapp Slug\n  },\n  // Future:\n  // { value: 'Teams', label: 'Teams (...)', appliesTo: ['Team','User'], gate: 'Teams Integration' },\n  // { value: 'SMS',   label: 'SMS (...)',   appliesTo: ['User'],         gate: 'SMS Integration' },\n  {\n    value: 'None',\n    label: 'None (Messages not sent to this team)',\n    appliesTo: ['Team'],\n  },\n  {\n    value: 'None',\n    label: 'None (Messages not sent to this user)',\n    appliesTo: ['User'],\n  },\n];\n\nconst isKappAttrTrue = (name) =>\n  String(kapp(`attribute:${name}`)).toLowerCase() === 'true';\n\nconst audience = values('Team or User'); // 'Team' or 'User'\n\nconst options = DELIVERY_METHODS\n  .filter(m => m.appliesTo.includes(audience))\n  .filter(m => !m.gate || isKappAttrTrue(m.gate))\n  .map(({ label, value }) => ({ label, value }));\n\nK('field[Notification Delivery Method]').options(options);",
                "integrationResourceName": null,
                "action": "Custom",
                "integrationResourceProperty": "",
                "type": "Change"
              },
